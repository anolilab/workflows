{
    "name": "gh-actions",
    "private": true,
    "type": "module",
    "scripts": {
        "preinstall": "node verify-node-version.cjs && npx only-allow pnpm",
        "prepare": "is-ci || husky || exit 0",
        "sort-package-json": "sort-package-json ./package.json"
    },
    "devDependencies": {
        "@anolilab/commitlint-config": "^10.0.0",
        "@anolilab/lint-staged-config": "^11.0.0",
        "@anolilab/prettier-config": "^10.0.0",
        "@anolilab/semantic-release-preset": "^13.4.6",
        "@commitlint/cli": "^20.5.2",
        "@commitlint/config-conventional": "^20.5.0",
        "@secretlint/secretlint-rule-preset-recommend": "^12.3.1",
        "commitizen": "^4.3.1",
        "conventional-changelog-conventionalcommits": "9.3.1",
        "cross-env": "^10.1.0",
        "husky": "^9.1.7",
        "is-ci": "^4.1.0",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "secretlint": "12.3.1",
        "semantic-release": "^25.0.3",
        "sort-package-json": "^3.6.1"
    },
    "packageManager": "pnpm@10.33.2",
    "engines": {
        "node": ">=22.13 <=25.*"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@anolilab/commitlint-config",
            "@anolilab/lint-staged-config",
            "@anolilab/prettier-config"
        ],
        "overrides": {
            "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
            "lodash@>=4.0.0 <=4.17.22": ">=4.18.1",
            "lodash@<=4.17.23": ">=4.18.0",
            "tmp@<=0.2.3": ">=0.2.5",
            "undici@<6.23.0": ">=6.25.0",
            "undici@<6.24.0": ">=6.25.0"
        }
    }
}
